{
  "name": "Feedback",
  "type": "object",
  "properties": {
    "feedback_text": {
      "type": "string",
      "description": "The feedback content from the user"
    },
    "user_email": {
      "type": "string",
      "description": "Email of the user providing feedback"
    },
    "submitted_date": {
      "type": "string",
      "format": "date-time",
      "description": "When the feedback was submitted"
    },
    "status": {
      "type": "string",
      "enum": [
        "new",
        "reviewed",
        "in_progress",
        "resolved"
      ],
      "default": "new",
      "description": "Status of the feedback"
    },
    "admin_notes": {
      "type": "string",
      "description": "Internal notes from admin"
    }
  },
  "required": [
    "feedback_text",
    "submitted_date"
  ]
}