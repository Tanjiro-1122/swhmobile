{
  "name": "Match",
  "type": "object",
  "properties": {
    "sport": {
      "type": "string",
      "description": "Type of sport (e.g., Basketball, Football, Baseball, Soccer)"
    },
    "league": {
      "type": "string",
      "description": "League or competition name"
    },
    "home_team": {
      "type": "string",
      "description": "Name of the home team - TEAM PLAYING AT THEIR OWN VENUE"
    },
    "away_team": {
      "type": "string",
      "description": "Name of the away team - TEAM TRAVELING/VISITING"
    },
    "venue": {
      "type": "string",
      "description": "Stadium/arena name and location where game is played"
    },
    "match_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date and time of the match"
    },
    "home_win_probability": {
      "type": "number",
      "description": "Probability of home team winning (0-100) - includes home advantage"
    },
    "away_win_probability": {
      "type": "number",
      "description": "Probability of away team winning (0-100)"
    },
    "draw_probability": {
      "type": "number",
      "description": "Probability of a draw (0-100)"
    },
    "key_factors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Key factors affecting the prediction"
    },
    "analysis_summary": {
      "type": "string",
      "description": "Brief summary of the analysis - must mention home advantage"
    },
    "confidence_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ],
      "description": "Confidence level of the prediction"
    },
    "key_players": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "team": {
            "type": "string",
            "description": "Include (HOME) or (AWAY) designation"
          },
          "position": {
            "type": "string"
          },
          "sport": {
            "type": "string",
            "description": "Sport the player plays"
          },
          "predicted_points": {
            "type": "number",
            "description": "Basketball/Soccer"
          },
          "predicted_assists": {
            "type": "number",
            "description": "Basketball/Soccer"
          },
          "predicted_rebounds": {
            "type": "number",
            "description": "Basketball"
          },
          "predicted_goals": {
            "type": "number",
            "description": "Soccer"
          },
          "predicted_hits": {
            "type": "number",
            "description": "Baseball"
          },
          "predicted_runs": {
            "type": "number",
            "description": "Baseball"
          },
          "predicted_rbis": {
            "type": "number",
            "description": "Baseball - Runs Batted In"
          },
          "predicted_home_runs": {
            "type": "number",
            "description": "Baseball"
          },
          "predicted_stolen_bases": {
            "type": "number",
            "description": "Baseball"
          },
          "predicted_passing_yards": {
            "type": "number",
            "description": "Football/NFL"
          },
          "predicted_passing_touchdowns": {
            "type": "number",
            "description": "Football/NFL"
          },
          "predicted_interceptions": {
            "type": "number",
            "description": "Football/NFL"
          },
          "predicted_rushing_yards": {
            "type": "number",
            "description": "Football/NFL"
          },
          "predicted_rushing_touchdowns": {
            "type": "number",
            "description": "Football/NFL"
          },
          "predicted_receiving_yards": {
            "type": "number",
            "description": "Football/NFL"
          },
          "predicted_receiving_touchdowns": {
            "type": "number",
            "description": "Football/NFL"
          },
          "predicted_receptions": {
            "type": "number",
            "description": "Football/NFL"
          },
          "probability_to_score": {
            "type": "number",
            "description": "Percentage chance to score (touchdown/goal/hit)"
          },
          "recent_form": {
            "type": "string"
          },
          "injury_status": {
            "type": "string"
          }
        }
      },
      "description": "Key players and their predicted contributions"
    },
    "betting_markets": {
      "type": "object",
      "properties": {
        "over_under": {
          "type": "object",
          "properties": {
            "line": {
              "type": "number"
            },
            "over_probability": {
              "type": "number"
            },
            "under_probability": {
              "type": "number"
            }
          }
        },
        "both_teams_score": {
          "type": "object",
          "properties": {
            "yes_probability": {
              "type": "number"
            },
            "no_probability": {
              "type": "number"
            }
          }
        },
        "total_goals_range": {
          "type": "object",
          "properties": {
            "predicted_total": {
              "type": "number"
            },
            "range": {
              "type": "string"
            }
          }
        },
        "first_to_score": {
          "type": "object",
          "properties": {
            "home_probability": {
              "type": "number",
              "description": "Home team typically 55-65%"
            },
            "away_probability": {
              "type": "number",
              "description": "Away team typically 35-45%"
            }
          }
        }
      }
    }
  },
  "required": [
    "sport",
    "home_team",
    "away_team",
    "venue",
    "home_win_probability",
    "away_win_probability"
  ]
}