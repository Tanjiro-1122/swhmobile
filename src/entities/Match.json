{
  "name": "Match",
  "type": "object",
  "properties": {
    "sport": {
      "type": "string",
      "description": "Type of sport (e.g., Football, Basketball, Tennis)"
    },
    "league": {
      "type": "string",
      "description": "League or competition name"
    },
    "home_team": {
      "type": "string",
      "description": "Name of the home team"
    },
    "away_team": {
      "type": "string",
      "description": "Name of the away team"
    },
    "match_date": {
      "type": "string",
      "format": "date-time",
      "description": "Date and time of the match"
    },
    "home_win_probability": {
      "type": "number",
      "description": "Probability of home team winning (0-100)"
    },
    "away_win_probability": {
      "type": "number",
      "description": "Probability of away team winning (0-100)"
    },
    "draw_probability": {
      "type": "number",
      "description": "Probability of a draw (0-100)"
    },
    "prediction": {
      "type": "object",
      "properties": {
        "winner": {
          "type": "string",
          "description": "Predicted winner team name"
        },
        "predicted_score": {
          "type": "string",
          "description": "Predicted final score"
        },
        "win_margin": {
          "type": "string",
          "description": "Predicted win margin"
        },
        "confidence": {
          "type": "string",
          "description": "Prediction confidence level"
        },
        "reasoning": {
          "type": "string",
          "description": "Explanation for the prediction"
        }
      },
      "description": "Match outcome prediction"
    },
    "key_factors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Key factors affecting the prediction"
    },
    "key_players": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "team": {
            "type": "string"
          },
          "position": {
            "type": "string"
          },
          "predicted_points": {
            "type": "number"
          },
          "predicted_assists": {
            "type": "number"
          },
          "predicted_rebounds": {
            "type": "number"
          },
          "predicted_goals": {
            "type": "number"
          },
          "predicted_passing_yards": {
            "type": "number"
          },
          "predicted_rushing_yards": {
            "type": "number"
          },
          "probability_to_score": {
            "type": "number"
          },
          "recent_form": {
            "type": "string"
          },
          "injury_status": {
            "type": "string"
          },
          "predicted_performance": {
            "type": "string"
          }
        }
      },
      "description": "Key players and their predicted contributions"
    },
    "betting_markets": {
      "type": "object",
      "properties": {
        "over_under": {
          "type": "object",
          "properties": {
            "line": {
              "type": "number"
            },
            "over_probability": {
              "type": "number"
            },
            "under_probability": {
              "type": "number"
            }
          }
        },
        "both_teams_score": {
          "type": "object",
          "properties": {
            "yes_probability": {
              "type": "number"
            },
            "no_probability": {
              "type": "number"
            }
          }
        },
        "total_goals_range": {
          "type": "object",
          "properties": {
            "predicted_total": {
              "type": "number"
            },
            "range": {
              "type": "string"
            }
          }
        },
        "first_to_score": {
          "type": "object",
          "properties": {
            "home_probability": {
              "type": "number"
            },
            "away_probability": {
              "type": "number"
            }
          }
        }
      }
    },
    "injuries": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "player_name": {
            "type": "string"
          },
          "team": {
            "type": "string"
          },
          "injury": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "impact": {
            "type": "string"
          }
        }
      },
      "description": "Current injury report"
    },
    "weather_impact": {
      "type": "object",
      "properties": {
        "conditions": {
          "type": "string"
        },
        "temperature": {
          "type": "string"
        },
        "wind_speed": {
          "type": "string"
        },
        "impact_rating": {
          "type": "string"
        },
        "betting_impact": {
          "type": "string"
        }
      },
      "description": "Weather conditions and impact on game"
    }
  },
  "required": [
    "sport",
    "home_team",
    "away_team",
    "home_win_probability",
    "away_win_probability",
    "prediction"
  ]
}