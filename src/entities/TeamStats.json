        "properties": {
          "date": {
            "type": "string"
          },
          "opponent": {
            "type": "string"
          },
          "result": {
            "type": "string"
          },
          "score": {
            "type": "string"
          },
          "home_away": {
            "type": "string"
          },
          "team_points": {
            "type": "number"
          },
          "opponent_points": {
            "type": "number"
          },
          "key_stats": {
            "type": "object"
          }
        }
      },
