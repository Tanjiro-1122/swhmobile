{
  "name": "User",
  "type": "object",
  "properties": {
    "subscription_type": {
      "type": "string",
      "enum": [
        "free",
        "legacy",
        "vip_annual",
        "premium_monthly"
      ],
      "default": "free",
      "description": "User's subscription tier - Legacy (grandfathered lifetime), VIP Annual ($149.99/year), Premium Monthly ($19.99/month), Free (5 lookups)"
    },
    "legacy_member_number": {
      "type": "number",
      "description": "Legacy member number (original first 20 members)"
    },
    "search_count": {
      "type": "number",
      "default": 0,
      "description": "Total number of searches performed"
    },
    "subscription_start_date": {
      "type": "string",
      "format": "date-time",
      "description": "When subscription started"
    },
    "subscription_end_date": {
      "type": "string",
      "format": "date-time",
      "description": "When subscription expires (for VIP Annual)"
    },
    "favorite_sports": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "User's favorite sports (e.g., NBA, NFL, MLB, Soccer, NHL)"
    },
    "favorite_leagues": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "default": [],
      "description": "User's favorite leagues (e.g., Premier League, La Liga, Champions League)"
    },
    "notification_preferences": {
      "type": "object",
      "properties": {
        "game_alerts": {
          "type": "boolean",
          "default": true,
          "description": "Receive alerts when games are starting"
        },
        "odds_changes": {
          "type": "boolean",
          "default": true,
          "description": "Receive alerts for significant odds movements"
        },
        "injury_updates": {
          "type": "boolean",
          "default": true,
          "description": "Receive alerts for key player injuries"
        },
        "betting_insights": {
          "type": "boolean",
          "default": true,
          "description": "Receive daily betting insights and recommendations"
        },
        "sharp_money_alerts": {
          "type": "boolean",
          "default": false,
          "description": "Receive alerts when sharp money moves lines"
        }
      },
      "default": {
        "game_alerts": true,
        "odds_changes": true,
        "injury_updates": true,
        "betting_insights": true,
        "sharp_money_alerts": false
      }
    },
    "display_preferences": {
      "type": "object",
      "properties": {
        "odds_format": {
          "type": "string",
          "enum": [
            "decimal",
            "american",
            "fractional"
          ],
          "default": "american",
          "description": "Preferred odds display format"
        },
        "stat_order": {
          "type": "string",
          "enum": [
            "default",
            "alphabetical",
            "importance"
          ],
          "default": "default",
          "description": "How to order statistics display"
        },
        "show_advanced_stats": {
          "type": "boolean",
          "default": false,
          "description": "Show advanced analytics by default"
        },
        "compact_view": {
          "type": "boolean",
          "default": false,
          "description": "Use compact card layouts"
        }
      },
      "default": {
        "odds_format": "american",
        "stat_order": "default",
        "show_advanced_stats": false,
        "compact_view": false
      }
    }
  },
  "required": []
}