            "type": "string"
          },
          "confidence": {
            "type": "string"
          },
          "reasoning": {
            "type": "string"
          }
        }
      },
      "description": "Top 3-5 picks for the day"
    },
    "injury_updates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "player": {
            "type": "string"
          },
          "team": {
            "type": "string"
