import { createClientFromRequest } from 'npm:@base44/sdk@0.7.1';

Deno.serve(async (req) => {
    try {
        const base44 = createClientFromRequest(req);
        
        // Get the authenticated user
        const user = await base44.auth.me();
        if (!user) {
            return Response.json({ error: 'Unauthorized' }, { status: 401 });
        }

        const today = new Date().toISOString().split('T')[0];

        // Check if brief already exists for this user today
        const existingBrief = await base44.asServiceRole.entities.BettingBrief.filter({
            brief_date: today,
            created_by: user.email
        });

        if (existingBrief.length > 0) {
            return Response.json({ 
                success: true, 
                message: 'Brief already exists for today',
                brief: existingBrief[0]
            });
        }

        // Get user's preferences
        const favoriteSports = user.favorite_sports || [];
        const favoriteLeagues = user.favorite_leagues || [];

        // Default sports/leagues if user hasn't set preferences
        const defaultSports = ['nba', 'nfl', 'mlb', 'soccer', 'nhl'];
        const defaultLeagues = ['premier_league', 'champions_league'];

        const sportsToFocus = favoriteSports.length > 0 ? favoriteSports : defaultSports;
        const leaguesToFocus = favoriteLeagues.length > 0 ? favoriteLeagues : defaultLeagues;

        // Map sport IDs to full names for better AI understanding
        const sportNames = {
            'nba': 'NBA Basketball',
            'nfl': 'NFL Football',
            'mlb': 'MLB Baseball',
            'nhl': 'NHL Hockey',
            'soccer': 'Soccer/Football',
            'ncaab': 'NCAA Basketball',
            'ncaaf': 'NCAA Football',
            'mma': 'MMA/UFC',
            'tennis': 'Tennis',
            'golf': 'Golf'
        };

        const leagueNames = {
            'premier_league': 'English Premier League',
            'la_liga': 'La Liga (Spain)',
            'bundesliga': 'Bundesliga (Germany)',
            'serie_a': 'Serie A (Italy)',
            'ligue_1': 'Ligue 1 (France)',
            'champions_league': 'UEFA Champions League',
            'europa_league': 'UEFA Europa League',
            'mls': 'MLS (USA)'
        };

        const focusedSportNames = sportsToFocus.map(id => sportNames[id] || id).join(', ');
        const focusedLeagueNames = leaguesToFocus.map(id => leagueNames[id] || id).join(', ');

        // Build personalized prompt
        const userPreferenceNote = favoriteSports.length > 0 
            ? `This brief is personalized for a user who follows: ${focusedSportNames}${favoriteLeagues.length > 0 ? ` and specifically these leagues: ${focusedLeagueNames}` : ''}.`
            : `This is a default brief covering popular sports: ${focusedSportNames}.`;

        // Generate comprehensive daily brief using AI
        const briefData = await base44.integrations.Core.InvokeLLM({
            prompt: `You are a professional sports betting analyst. Create a comprehensive PERSONALIZED daily betting brief for ${new Date().toLocaleDateString('en-US', { weekday: 'long', month: 'long', day: 'numeric', year: 'numeric' })}.

${userPreferenceNote}

🎯 CRITICAL PERSONALIZATION RULES:
- FOCUS EXCLUSIVELY on games from: ${focusedSportNames}
${favoriteLeagues.length > 0 ? `- For soccer, PRIORITIZE these leagues: ${focusedLeagueNames}` : ''}
- DO NOT include picks from sports the user doesn't follow
- All picks, injury updates, and line movements MUST be from the user's preferred sports/leagues
- If there are no games today from preferred sports, acknowledge this and suggest checking back tomorrow

REQUIRED SECTIONS:

1. EXECUTIVE SUMMARY (3-4 sentences):
   - Overall betting landscape for TODAY in the user's preferred sports
   - Market sentiment for ${focusedSportNames}
   - Key themes to watch in these specific sports/leagues

2. TOP PICKS (3-5 picks from user's preferred sports ONLY):
   For each pick provide:
   - Sport and league (MUST be from: ${focusedSportNames})
   - Match (Team A vs Team B)
   - Specific pick (e.g., "Lakers -5.5", "Over 225.5", "Mahomes Over 2.5 TDs")
   - Current odds (realistic odds like -110, +150, etc.)
   - Confidence level (High/Medium/Low)
   - 2-3 sentence reasoning with specific stats

3. KEY INJURY UPDATES (3-5 updates from user's preferred sports):
   - Player name and team (from ${focusedSportNames} ONLY)
   - Injury type and status
   - Impact on betting (High/Medium/Low)

4. SIGNIFICANT LINE MOVEMENTS (2-3 movements from user's sports):
   - Which game/bet (from ${focusedSportNames})
   - How the line moved (e.g., "Moved from -3.5 to -5.5")
   - Why it's significant

5. SHARP MONEY INDICATORS (3-4 indicators from user's sports):
   - Where professional bettors are placing money
   - Specific games and bet types (from ${focusedSportNames})

6. WEATHER ALERTS (if applicable to user's sports):
   - Outdoor games affected by weather (NFL, MLB, outdoor soccer)
   - Conditions and betting impact

Use REAL, CURRENT data from the internet. Search for:
- TODAY'S game schedules from ESPN, CBS Sports for ${focusedSportNames}
${favoriteLeagues.length > 0 ? `- Specific focus on ${focusedLeagueNames} fixtures` : ''}
- Current odds from major sportsbooks
- Recent injury reports from team websites
- Weather forecasts for outdoor stadiums

IMPORTANT: If there are NO games today from the user's preferred sports/leagues, include this in the summary and suggest checking back tomorrow. Don't fabricate games from sports they don't follow.

Return comprehensive JSON with all sections filled, focusing ONLY on ${focusedSportNames}.`,
            add_context_from_internet: true,
            response_json_schema: {
                type: "object",
                properties: {
                    summary: { type: "string" },
                    top_picks: {
                        type: "array",
                        items: {
                            type: "object",
                            properties: {
                                sport: { type: "string" },
                                match: { type: "string" },
                                pick: { type: "string" },
                                odds: { type: "string" },
                                confidence: { type: "string" },
                                reasoning: { type: "string" }
                            }
                        }
                    },
                    injury_updates: {
                        type: "array",
                        items: {
                            type: "object",
                            properties: {
                                player: { type: "string" },
                                team: { type: "string" },
                                injury: { type: "string" },
                                impact: { type: "string" }
                            }
                        }
                    },
                    line_movements: {
                        type: "array",
                        items: {
                            type: "object",
                            properties: {
                                match: { type: "string" },
                                movement: { type: "string" },
                                significance: { type: "string" }
                            }
                        }
                    },
                    sharp_money_indicators: {
                        type: "array",
                        items: { type: "string" }
                    },
                    weather_alerts: {
                        type: "array",
                        items: {
                            type: "object",
                            properties: {
                                match: { type: "string" },
                                conditions: { type: "string" },
                                impact: { type: "string" }
                            }
                        }
                    }
                },
                required: ["summary", "top_picks"]
            }
        });

        // Create the personalized brief in database
        const brief = await base44.asServiceRole.entities.BettingBrief.create({
            brief_date: today,
            user_email: user.email,
            title: `Personalized Feed - ${new Date().toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}`,
            summary: briefData.summary,
            focused_sports: sportsToFocus,
            focused_leagues: leaguesToFocus,
            top_picks: briefData.top_picks || [],
            injury_updates: briefData.injury_updates || [],
            line_movements: briefData.line_movements || [],
            sharp_money_indicators: briefData.sharp_money_indicators || [],
            weather_alerts: briefData.weather_alerts || []
        });

        return Response.json({ 
            success: true, 
            message: 'Personalized feed generated successfully',
            brief: brief
        });
    } catch (error) {
        console.error('Generate daily brief error:', error);
        return Response.json({ error: error.message }, { status: 500 });
    }
});