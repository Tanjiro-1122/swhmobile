# Required: Get a FREE API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Optional: Odds API (free tier at https://the-odds-api.com - 500 req/month free)
ODDS_API_KEY=your_odds_api_key_here

# Optional: Enable web search for sports news context
SEARCH_ENABLED=true

# Server config
PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,https://sports-wager-helper.vercel.app

# Cache TTL in seconds
CACHE_TTL=300
